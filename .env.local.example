# --- 任意：Next のビルド出力先（Windows 既定は .next-local） ---
# OneDrive 等で routes-manifest 欠落・readlink エラーになる場合は次の行のコメントを外して試す。
# NEXT_DIST_DIR=.next

# GrowthCore API（アカウント診断）
# ローカル: $ は \$ でエスケープ。Vercel: そのまま貼る（エスケープ不要）。
ACCOUNT_OPTIMIZATION_API_KEY=your_api_key_here

# お問い合わせフォームURL
NEXT_PUBLIC_CONTACT_FORM_URL=https://your-contact-form-url.com

# --- 任意：reCAPTCHA v3（未設定なら検証はスキップされます） ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key

# Thanks 経由時に Instagram ID を送る先（資料請求アプリ）のベース URL。未設定の場合は送信しない。
NEXT_PUBLIC_HP_API_BASE=https://instagram-marketing-inquiry-form.vercel.app
# 上記ベースURLに対する set-instagram のパス。未設定時は /api/contact/set-instagram
# NEXT_PUBLIC_HP_SET_INSTAGRAM_PATH=/api/contact/set-instagram

# 管理者用秘密キー（入力ID一覧を見るために必要）
# 注意: 秘密キーに $ 記号が含まれる場合は、バックスラッシュでエスケープしてください
ADMIN_SECRET_KEY=your_strong_secret_key_here

# Upstash Redis（入力ID一覧・診断結果・レート制限用）
# 無料診断・別ドキュメントなどに既に書かれている URL / トークンとは、環境や用途で異なる場合があります。
# ローカル・Vercel それぞれで使う DB の REST 情報を、Upstash ダッシュボードで確認して設定してください。
# 必ず Upstash コンソール（https://console.upstash.com）で DB を作成し、
# 「REST API」に表示される URL と UPSTASH_REDIS_REST_TOKEN をそのまま設定すること。
# 下記の your-database-id は動きません（サンプル用のダミーです）。
UPSTASH_REDIS_REST_URL=https://your-database-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# --- Supabase（資料・テンプレ・申請履歴。未設定時は Redis のみでダウンロード申請を表示） ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- 必須：SendGrid（開発環境でメール送信する場合。未設定の場合は email_status は pending のまま） ---
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=info@nishinippon-adv.jp

# メール内の資料リンク署名 URL の有効期限（秒）。既定 604800（7日）
DOCUMENT_SIGNED_URL_TTL_SEC=604800

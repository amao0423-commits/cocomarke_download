# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies（プロジェクト直下の node_modules が無視されます）
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js（ビルド出力用フォルダが無視されます）
/.next/
/.next-local/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (do not commit these!)
# .env.local, .env.development.local, .env.production.local などが無視されます
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data files（入力ID一覧・診断結果用。プロジェクト直下の data フォルダ全体が無視されます）
/data
